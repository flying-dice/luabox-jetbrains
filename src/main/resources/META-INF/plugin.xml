<!--
  require-restart: this plugin registers non-dynamic extension points (a
  <fileType> association and an LSP4IJ <server>), which the platform can't load
  on the fly. Declaring it forces the IDE to surface the Restart button on
  install/update instead of half-applying a dynamic load that leaves the plugin
  installed but inert until the next restart.
-->
<idea-plugin require-restart="true">
    <id>dev.pseudoscript.pds</id>
    <name>PseudoScript</name>
    <vendor email="hello@pseudoscript.dev" url="https://pseudoscript.dev">PseudoScript</vendor>

    <description><![CDATA[
        <p>Language support for <b>PseudoScript</b> (<code>.pds</code>) — a
        <b>pseudoprogramming</b> language: you code the abstraction and let it
        autogenerate, rather than hand-maintaining the output. It reads like
        pseudocode, expresses C4-style structure (system / container /
        component / person), and compiles to SVG diagrams.</p>

        <h3>Features</h3>
        <ul>
            <li><b>Syntax highlighting</b>, comment toggling, and a color-scheme
                page (bundled, no server needed).</li>
            <li><b>Diagnostics, hover, formatting, and go-to-definition</b> via
                the <code>pds lsp</code> language server.</li>
            <li><b>Build / Serve Docs</b> — right-click a <code>pds.toml</code>
                to generate the documentation site (<code>pds doc</code>) or
                serve it locally (<code>pds doc --serve</code>).</li>
        </ul>

        <h3>Requirements</h3>
        <ul>
            <li>The <a href="https://plugins.jetbrains.com/plugin/23257-lsp4ij">LSP4IJ</a>
                plugin (installed automatically as a dependency).</li>
            <li>The <code>pds</code> binary on your <code>PATH</code>, or its
                location set in
                <i>Settings &gt; Languages &amp; Frameworks &gt; PseudoScript</i>.</li>
        </ul>
    ]]></description>

    <change-notes><![CDATA[
        <ul>
            <li><b>0.6.0</b> — The plugin now requires an IDE restart on
                install / update. It registers a file type and an LSP server,
                which can't be loaded dynamically, so the IDE prompts to restart
                instead of silently installing without effect.</li>
            <li><b>0.5.0</b> — Modernised deprecated platform APIs; the minimum
                supported IDE is now <b>2025.1</b>.</li>
            <li><b>0.4.0</b> — A <b>search box</b> in the PseudoScript tool window's
                Structure tab: filter the workspace symbol tree live by name, FQN,
                or kind, keeping the path to every match.</li>
            <li><b>0.3.0</b> — A <b>Help</b> button (top-right of the PseudoScript
                tool window) with a quick intro to PseudoProgramming and a
                paste-ready prompt that has any coding agent install the
                PseudoScript skill (<code>pds skill</code>) and write your model.
                Plus an editor banner warning when the <code>pds</code> binary is
                missing.</li>
            <li><b>0.2.0</b> — A visual <b>PseudoScript</b> tool window:
                <ul>
                    <li><b>Structure</b> — the workspace symbol tree (monorepo-aware);
                        click a node, or <i>PseudoScript &gt; Open Diagram</i> in the
                        editor, to render its C4 view or flow sequence as a zoomable,
                        pannable diagram with SVG / PNG export.</li>
                    <li><b>Docs</b> — build &amp; serve the documentation site and
                        preview it live (auto-reloading) in an embedded browser.</li>
                </ul>
                Diagrams follow the IDE's light / dark theme.</li>
            <li><b>0.1.0</b> — Initial release: syntax highlighting, LSP-backed
                diagnostics / hover / formatting / go-to-definition, and a
                Build / Serve Docs context menu on <code>pds.toml</code>.</li>
        </ul>
    ]]></change-notes>

    <!-- Platform + the LSP4IJ client runtime. -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="PseudoScript"
            implementationClass="dev.pseudoscript.lang.PseudoScriptFileType"
            fieldName="INSTANCE"
            language="PseudoScript"
            extensions="pds"/>

        <lang.syntaxHighlighterFactory
            language="PseudoScript"
            implementationClass="dev.pseudoscript.highlight.PseudoScriptSyntaxHighlighterFactory"/>

        <!--
          Give .pds files LSP4IJ's semantic-token-based PSI: one element per
          token with a navigation reference. This scopes Cmd-hover/Cmd-click to
          the symbol under the caret (instead of the whole file) and keeps the
          semantic-token colouring on LSP4IJ's intended path. Requires LSP4IJ ≥
          the version that ships this view provider.
        -->
        <lang.fileViewProviderFactory
            language="PseudoScript"
            implementationClass="com.redhat.devtools.lsp4ij.features.semanticTokens.viewProvider.LSPSemanticTokensStructurelessFileViewProviderFactory"/>

        <!--
          Native Structure view (⌘7) for .pds files. LSP4IJ's structure-view support
          is language-scoped: its generic builder delegates to the
          lang.psiStructureViewFactory registered for the file's Language, and LSP4IJ
          only self-registers for TEXT / textmate. Point PseudoScript at the same
          factory so the LSP `documentSymbol` outline (served by `pds lsp`) populates
          the Structure tool window.
        -->
        <lang.psiStructureViewFactory
            language="PseudoScript"
            implementationClass="com.redhat.devtools.lsp4ij.features.documentSymbol.LSPDocumentSymbolStructureViewFactory"/>

        <lang.commenter
            language="PseudoScript"
            implementationClass="dev.pseudoscript.lang.PseudoScriptCommenter"/>

        <lang.braceMatcher
            language="PseudoScript"
            implementationClass="dev.pseudoscript.lang.PseudoScriptBraceMatcher"/>

        <colorSettingsPage
            implementation="dev.pseudoscript.highlight.PseudoScriptColorSettingsPage"/>

        <applicationService
            serviceImplementation="dev.pseudoscript.settings.PseudoScriptSettings"/>

        <applicationConfigurable
            parentId="language"
            instance="dev.pseudoscript.settings.PseudoScriptConfigurable"
            id="dev.pseudoscript.settings.PseudoScriptConfigurable"
            displayName="PseudoScript"/>

        <!--
          The diagram editor: opens a synthetic DiagramVirtualFile (produced by
          the structure tool window) into a zoomable SVG canvas rendered from
          `pds svg`. HIDE_DEFAULT_EDITOR keeps the text editor off it.
        -->
        <fileEditorProvider
            implementation="dev.pseudoscript.diagram.DiagramFileEditorProvider"/>

        <!--
          The structure tool window: the workspace's symbol tree (from
          `pds outline`); selecting a node renders its diagram in the editor area.
        -->
        <toolWindow
            id="PseudoScript"
            anchor="right"
            icon="dev.pseudoscript.lang.PseudoScriptIcons.GREY"
            factoryClass="dev.pseudoscript.diagram.PdsStructureToolWindowFactory"/>

        <!-- Balloon shown after a diagram is exported to disk. -->
        <notificationGroup
            id="PseudoScript"
            displayType="BALLOON"/>

        <!--
          Warns atop `.pds` / `pds.toml` files when the `pds` binary is missing:
          highlighting works, but diagnostics / diagrams / docs need it. Clears
          once a valid path is configured.
        -->
        <editorNotificationProvider
            implementation="dev.pseudoscript.notification.PdsMissingBinaryEditorNotificationProvider"/>
    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server
            id="pseudoscript"
            name="PseudoScript Language Server"
            factoryClass="dev.pseudoscript.lsp.PseudoScriptLanguageServerFactory">
            <description><![CDATA[
                The <code>pds lsp</code> stdio language server.
            ]]></description>
        </server>

        <languageMapping
            language="PseudoScript"
            serverId="pseudoscript"
            languageId="pseudoscript"/>

        <!-- Route `pds lsp` semantic tokens to the plugin's PseudoScript colours. -->
        <semanticTokensColorsProvider
            serverId="pseudoscript"
            class="dev.pseudoscript.lsp.PseudoScriptSemanticTokensColorsProvider"/>
    </extensions>

    <actions>
        <group
            id="dev.pseudoscript.PdsTomlActions"
            class="dev.pseudoscript.actions.PdsTomlActionGroup"
            text="PseudoScript"
            popup="true"
            icon="dev.pseudoscript.lang.PseudoScriptIcons.GREY">
            <!-- Shown on a `.pds` source file. -->
            <action
                id="dev.pseudoscript.OpenDiagram"
                class="dev.pseudoscript.diagram.OpenDiagramAction"
                text="Open Diagram"
                description="Render this symbol's PseudoScript diagram"
                icon="dev.pseudoscript.lang.PseudoScriptIcons.GREY"/>
            <!-- Shown on a `pds.toml` project root. -->
            <action
                id="dev.pseudoscript.BuildDocs"
                class="dev.pseudoscript.actions.BuildDocsAction"
                text="Build Docs"
                description="Generate the documentation site (pds doc)."
                icon="AllIcons.Actions.Compile"/>
            <action
                id="dev.pseudoscript.ServeDocs"
                class="dev.pseudoscript.actions.ServeDocsAction"
                text="Serve Docs"
                description="Generate and serve the documentation site (pds doc --serve)."
                icon="AllIcons.Actions.Execute"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorTabPopupMenu" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
