<!--
  require-restart: this plugin registers non-dynamic extension points (a
  <fileType> association and an LSP4IJ <server>), which the platform can't load
  on the fly. Declaring it forces the IDE to surface the Restart button on
  install/update instead of half-applying a dynamic load that leaves the plugin
  installed but inert until the next restart.
-->
<idea-plugin require-restart="true">
    <id>com.luabox</id>
    <name>luabox</name>
    <vendor email="hello@flying-dice.com" url="https://github.com/flying-dice/luabox">flying-dice</vendor>

    <description><![CDATA[
        <p>Lua language support for JetBrains IDEs, powered by the
        <b>luabox</b> toolchain's language server (<code>luabox lsp</code>) —
        a unified Lua typechecker, linter, formatter, and package manager.</p>

        <h3>Features</h3>
        <ul>
            <li><b>Base syntax highlighting</b> for <code>.lua</code> files
                (keywords, strings, numbers, comments) — bundled, works with no
                binary installed.</li>
            <li><b>Diagnostics with quick-fixes, hover, completion, go-to-definition,
                document symbols, formatting, and semantic highlighting</b> via
                the <code>luabox lsp</code> language server.</li>
        </ul>

        <h3>Requirements</h3>
        <ul>
            <li>The <a href="https://plugins.jetbrains.com/plugin/23257-lsp4ij">LSP4IJ</a>
                plugin (installed automatically as a dependency).</li>
            <li>The <code>luabox</code> binary on your <code>PATH</code> or in
                <code>~/.luabox/bin</code>, or its location set in
                <i>Settings &gt; Languages &amp; Frameworks &gt; luabox</i>.
                Get it from
                <a href="https://github.com/flying-dice/luabox/releases">the luabox releases</a>.</li>
        </ul>

        <p><i>Forked from
        <a href="https://github.com/flying-dice/pseudoscript-jetbrains">flying-dice/pseudoscript-jetbrains</a>.</i></p>
    ]]></description>

    <change-notes><![CDATA[
        <ul>
            <li><b>0.1.0</b> — Initial release: <code>.lua</code> file type with
                bundled base syntax highlighting, and LSP-backed diagnostics,
                hover, completion, go-to-definition, document symbols, formatting,
                and semantic highlighting via <code>luabox lsp</code>.</li>
        </ul>
    ]]></change-notes>

    <!-- Platform + the LSP4IJ client runtime. -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="Lua (luabox)"
            implementationClass="com.luabox.lang.LuaFileType"
            fieldName="INSTANCE"
            language="luabox"
            extensions="lua"/>

        <lang.syntaxHighlighterFactory
            language="luabox"
            implementationClass="com.luabox.highlight.LuaSyntaxHighlighterFactory"/>

        <!--
          Give .lua files LSP4IJ's semantic-token-based PSI: one element per
          token with a navigation reference. This scopes hover/click to the
          symbol under the caret (instead of the whole file) and keeps the
          semantic-token colouring on LSP4IJ's intended path.
        -->
        <lang.fileViewProviderFactory
            language="luabox"
            implementationClass="com.redhat.devtools.lsp4ij.features.semanticTokens.viewProvider.LSPSemanticTokensStructurelessFileViewProviderFactory"/>

        <!--
          Native Structure view (Alt-7) for .lua files, populated from the LSP
          `documentSymbol` outline served by `luabox lsp`. LSP4IJ's generic
          builder delegates to the psiStructureViewFactory registered for the
          file's Language, so point luabox at LSP4IJ's document-symbol factory.
        -->
        <lang.psiStructureViewFactory
            language="luabox"
            implementationClass="com.redhat.devtools.lsp4ij.features.documentSymbol.LSPDocumentSymbolStructureViewFactory"/>

        <lang.commenter
            language="luabox"
            implementationClass="com.luabox.lang.LuaCommenter"/>

        <applicationService
            serviceImplementation="com.luabox.settings.LuaboxSettings"/>

        <applicationConfigurable
            parentId="language"
            instance="com.luabox.settings.LuaboxConfigurable"
            id="com.luabox.settings.LuaboxConfigurable"
            displayName="luabox"/>

        <!--
          Warns atop `.lua` files when the `luabox` binary is missing: base
          highlighting works, but diagnostics / hover / completion / formatting
          need it. Clears once a valid path is configured.
        -->
        <editorNotificationProvider
            implementation="com.luabox.notification.LuaboxMissingBinaryEditorNotificationProvider"/>
    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server
            id="luabox"
            name="luabox Language Server"
            factoryClass="com.luabox.lsp.LuaboxLanguageServerFactory">
            <description><![CDATA[
                The <code>luabox lsp</code> stdio language server.
            ]]></description>
        </server>

        <languageMapping
            language="luabox"
            serverId="luabox"
            languageId="lua"/>
    </extensions>
</idea-plugin>
